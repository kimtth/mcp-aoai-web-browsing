{
    "servers": {
        "browser-navigator": {
            "type": "stdio",
            "command": "uv",
            "args": [
                "run",
                "fastmcp",
                "run",
                "./server/browser_navigator_server.py:app"
            ],
            "env": {
                "AZURE_OPEN_AI_ENDPOINT": "${env:AZURE_OPEN_AI_ENDPOINT}",
                "AZURE_OPEN_AI_API_KEY": "${env:AZURE_OPEN_AI_API_KEY}",
                "AZURE_OPEN_AI_DEPLOYMENT_MODEL": "${env:AZURE_OPEN_AI_DEPLOYMENT_MODEL}",
                "AZURE_OPEN_AI_API_VERSION": "${env:AZURE_OPEN_AI_API_VERSION}"
            }
        }
    }
}
